# Django — copy to backend/.env for local development
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1

# Local dev uses core.settings (core.settings.local)
# Railway production: DJANGO_SETTINGS_MODULE=core.settings.production
#
# Railway runtime variables (required):
#   DJANGO_SETTINGS_MODULE=core.settings.production
#   SECRET_KEY          — generate with get_random_secret_key()
#   DATABASE_URL        — set automatically when PostgreSQL plugin is attached
#   DEBUG=0             — production.py forces DEBUG=False regardless
#
# Recommended (idempotent init_admin on deploy):
#   DJANGO_SUPERUSER_USERNAME
#   DJANGO_SUPERUSER_PASSWORD
#
# Generate SECRET_KEY:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# Optional — same-origin deploy uses /api; only needed for split frontend hosting
# CORS_ALLOWED_ORIGINS=https://your-app.up.railway.app

# Local SQLite — omit DATABASE_URL. Railway sets DATABASE_URL automatically.
# DATABASE_SSLMODE=disable  — optional override (defaults to disable on Railway)
# DATABASE_URL=postgresql://user:password@host:port/railway

# Auto-created on deploy via: python manage.py init_admin
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_PASSWORD=change-me

# DEBUG=1: allow phones on same Wi-Fi (ALLOWED_HOSTS=* + LAN CORS regex). Set 0 to disable.
DJANGO_DEV_ALLOW_LAN=1
