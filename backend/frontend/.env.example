# Next.js frontend — copy to backend/frontend/.env.local
#
# Local desktop dev (http://localhost:3000): API auto-targets http://127.0.0.1:8000/api
# Mobile on Wi-Fi (http://YOUR_LAN_IP:3000): API auto-targets http://YOUR_LAN_IP:8000/api
#
# Production (Railway): NEXT_PUBLIC_API_URL=/api is set in railway.toml at build time
#
# NEXT_PUBLIC_API_URL is only needed for overrides:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api

# Optional: allow Next.js dev server from LAN IP (mobile testing)
# NEXT_ALLOWED_DEV_ORIGINS=192.168.1.100
