# Django — copy to .env and adjust for your machine
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1

# Comma-separated hosts (used when DEBUG=0 or DJANGO_DEV_ALLOW_LAN=0)
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.100

# Comma-separated frontend origins for CORS (used when DEBUG=0 or DJANGO_DEV_ALLOW_LAN=0)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.100:3000

# DEBUG=1: allow phones on same Wi‑Fi (ALLOWED_HOSTS=* + LAN CORS regex). Set 0 to disable.
DJANGO_DEV_ALLOW_LAN=1
