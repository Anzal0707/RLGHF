# Django — copy to backend/.env for local development
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1

# Local dev uses core.settings (core.settings.local)
# Railway production: DJANGO_SETTINGS_MODULE=core.settings.production

# Comma-separated hosts (production default includes .railway.app)
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# Comma-separated frontend origins for CORS
# Replace https://your-app.vercel.app with your real Vercel URL
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Railway PostgreSQL (set automatically on Railway; omit for local SQLite)
# DATABASE_URL=postgresql://user:password@host:port/railway
# DATABASE_SSLMODE=require

# DEBUG=1: allow phones on same Wi-Fi (ALLOWED_HOSTS=* + LAN CORS regex). Set 0 to disable.
DJANGO_DEV_ALLOW_LAN=1
